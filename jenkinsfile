pipeline
{
	agent any

	tools{
	maven "maven"
	}

	stages
	{
	stage('git')
	{
	steps
	{
	git branch: 'dev', credentialsId: '858e99fe-4a77-4bec-86ce-4220ba460921', url: 'https://github.com/my-first-orga/deploye-war-tomcat.git'
	}
	}
	stage('build')
	{
	steps
	{
	sh "mvn clean package"
	}
	}
	stage('sonar')
	{
	steps
	{
	sh "mvn clean sonar:sonar"
	}
	}
	stage('nexus')
	{
	steps
	{
	sh "mvn clean deploy"
	}
	}
	stage('tomcat deploy')
	{
	steps
	{
	sh """
        curl -u admin:admin \
            --upload-file /var/lib/jenkins/workspace/multibranch-pipe/target/maven-web-application.war \
            "http://18.206.117.65:8080/manager/text/deploy?path=/maven-web-application&update=true"
        """
	}
	}
	}
}
