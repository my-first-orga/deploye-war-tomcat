pipeline
{
  agent any

  tools
  {
  maven "maven"
  }

  stages
  {
  stage('git')
  {
  steps
  {
  git branch: 'f2', credentialsId: '1da0753f-0076-4bc8-8b51-821fea43c81c', url: 'https://github.com/my-first-orga/deploye-war-tomcat.git'
  }
  }
  stage('build')
  {
  steps
  {
  sh "mvn clean package"
  }
  }
  stage('sonar report')
  {
  steps
  {
  sh "mvn clean sonar:sonar"
  }
  }
  stage('nexus')
  {
  steps
  {
  sh "mvn clean deploy"
  }
  }
  stage('deploy tomcat')
  {
  steps
  {
 sh """
        curl -u admin:admin \
            --upload-file /var/lib/jenkins/workspace/declaretive/target/maven-web-application.war \
            "http://44.202.142.147:8080/manager/text/deploy?path=/maven-web-application&update=true"
        """
  }
  }
  }
}
